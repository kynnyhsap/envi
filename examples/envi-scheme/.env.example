# Provider-agnostic example using envi:// scheme
# Works with any provider — envi:// is converted to the provider's native format
# Vault: example

NODE_ENV=development
PORT=3000

# These references work with --provider 1password OR --provider proton-pass
API_KEY=envi://example/api-service/API_KEY
DATABASE_URL=envi://example/api-service/DATABASE_URL
JWT_SECRET=envi://example/api-service/JWT_SECRET
