# Proton Pass multi-environment example
# Uses ${ENV} substitution to switch between vaults
# Vault naming: example-local, example-staging, example-prod

NODE_ENV=development
PORT=3000

# Secrets — vault changes based on --env flag
API_KEY=pass://example-${ENV}/api-service/API_KEY
DATABASE_URL=pass://example-${ENV}/api-service/DATABASE_URL
REDIS_URL=pass://example-${ENV}/api-service/REDIS_URL
