{
  "name": "envi-cli",
  "version": "0.6.1",
  "description": "Envi syncs your .env files from 1Password — so you never copy secrets by hand again.",
  "bin": {
    "envi": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun run build.ts && tsc -p tsconfig.build.json",
    "cli": "bun run src/cli.ts",
    "bench:e2e": "bun run examples/1password-e2e-bench/bench.ts",
    "envi": "bun run src/cli.ts",
    "examples:cleanup": "bun run examples/cleanup.ts",
    "examples:setup": "bun run examples/setup.ts",
    "verify:publish": "bun run typecheck && bun run lint && bun test",
    "verify:live": "bun run test:e2e:1password:preflight && bun run test:e2e:1password",
    "test:all": "bun test && bun run verify:live",
    "test": "bun test",
    "test:e2e:1password": "bun run test:e2e:1password:run; code=$?; bun run test:e2e:1password:cleanup; exit $code",
    "test:e2e:1password:run": "bun test --timeout 600000 ./src/cli/cli.1password.live.e2e.ts",
    "test:e2e:1password:cleanup": "bun run src/testing/onepassword-e2e-cleanup.ts --include-shared",
    "test:e2e:1password:preflight": "bun run src/testing/onepassword-ratelimit-preflight.ts",
    "typecheck": "tsgo --noEmit",
    "fmt": "oxfmt --write .",
    "lint": "oxlint .",
    "build:cli": "bun run build",
    "build:sdk": "bun run build",
    "prepublishOnly": "bun run verify:publish",
    "prepack": "rm -rf dist && bun run build",
    "compile": "bun build --compile --minify src/cli.ts --outfile dist/envi"
  },
  "dependencies": {
    "@1password/sdk": "0.4.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cac": "7.0.0",
    "console-table-printer": "^2.15.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260310.1",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "typescript": "^5.0.0"
  }
}
