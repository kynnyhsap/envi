{
  "name": "envi-cli",
  "version": "0.3.1",
  "description": "Envi syncs your .env files from 1Password — so you never copy secrets by hand again.",
  "bin": {
    "envi": "./src/cli.ts"
  },
  "files": [
    "src",
    "dist/sdk",
    "README.md",
    "AGENTS.md",
    "examples"
  ],
  "type": "module",
  "exports": {
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "cli": "bun run src/cli.ts",
    "bench:e2e": "bun run examples/1password-e2e-bench/bench.ts",
    "envi": "bun run src/cli.ts",
    "examples:cleanup": "bun run examples/cleanup.ts",
    "examples:setup": "bun run examples/setup.ts",
    "test": "bun test",
    "test:e2e:1password": "bun test --timeout 600000 ./src/cli/cli.1password.live.e2e.ts",
    "typecheck": "tsgo --noEmit",
    "fmt": "oxfmt --write .",
    "lint": "oxlint .",
    "build:sdk": "bun build src/sdk/index.ts --outdir dist/sdk --target node --format esm && tsc -p tsconfig.build.json",
    "prepack": "bun run build:sdk",
    "compile": "bun build --compile --minify src/cli.ts --outfile dist/envi"
  },
  "dependencies": {
    "@1password/sdk": "0.4.0",
    "@inquirer/prompts": "^8.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260129.1",
    "cac": "7.0.0",
    "console-table-printer": "^2.15.0",
    "picocolors": "^1.1.1",
    "timeago.js": "^4.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "typescript": "^5.0.0"
  }
}
